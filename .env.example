# ============================================================================
# Project Panopticon — environment template
# Copy to deploy/.env and fill in, or simply run deploy/bootstrap.sh which
# generates all of these with randomized values (mode 600).
# NEVER commit the real .env — it is covered by .gitignore.
# ============================================================================

# --- Required secrets --------------------------------------------------------
NEO4J_PASSWORD=change-me                # compose fails fast if unset (:? guard)
LIVEKIT_API_KEY=lk_change-me            # production LiveKit key pair; the
LIVEKIT_API_SECRET=change-me            # bundled livekit service runs --dev
                                        # (well-known keys) ONLY behind the
                                        # opt-in "media" profile — never expose
                                        # that port publicly with --dev active
GRAFANA_ADMIN_PASSWORD=change-me        # anonymous access is OFF by default

# --- Deployment assumptions (override for non-RunPod hosts) ------------------
PANOPTICON_WORKSPACE=/workspace         # durable root: models, qdrant, neo4j,
                                        # snapshots, dead-letters, dashboards
DEAD_LETTER_DIR=/app/deadletter         # where unwritable graph mutations park
                                        # (replayable JSONL — contains agent
                                        # memory payloads; treat as data)
GRAFANA_ANONYMOUS=false                 # "true" only on a private pod

# --- Optional ----------------------------------------------------------------
# HF_TOKEN=                             # only if you swap in gated models;
                                        # bootstrap pulls Qwen3-8B / bge-m3
                                        # which need no token
